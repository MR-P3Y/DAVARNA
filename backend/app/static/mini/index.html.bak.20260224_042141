<!doctype html>
<html lang="fa" dir="rtl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Davarna Mini App</title>
    <link rel="stylesheet" href="./styles.css?v=20260224g" />
  </head>
  <body>
    <div class="app-shell">
      <header class="topbar glass">
        <div class="brand">
          <img id="brandLogo" class="brand-logo" src="./assets/bot-logo.jpg?v=20260224a" alt="لوگوی دورنای پیمون" />
          <div>
            <h1 id="brandTitle">دورنای پیمون</h1>
          </div>
        </div>
        <div class="smart-head">
          <div class="smart-chip">
            <span id="headerUserLabel">User</span>
            <strong id="headerUserName">-</strong>
          </div>
          <div class="smart-chip">
            <span id="headerWalletMiniLabel">Wallet</span>
            <strong id="headerWalletBalance">-</strong>
          </div>
          <div id="headerUserStatus" class="smart-chip status normal">Normal</div>
        </div>
        <div class="topbar-actions">
          <button id="themeBtn" class="icon-btn" type="button" aria-label="theme">◐</button>
          <span id="authBadge" class="badge pending">...</span>
        </div>
      </header>

      <main class="content">
        <section id="view-games" class="view active">
          <article class="glass panel">
            <div class="panel-head">
              <h2 id="gamesTitle">Games</h2>
              <button id="refreshGamesBtn" class="small-btn" type="button">Refresh</button>
            </div>
            <p id="gamesHint" class="hint">Active games</p>
            <div id="hotGameBanner" class="hot-banner hidden"></div>
            <div id="gamesList" class="stack-list"></div>
          </article>

          <article class="glass panel">
            <div class="panel-head">
              <h2 id="recentStatsTitle">Recent Stats</h2>
            </div>
            <div id="recentStatsSlider" class="h-scroll-cards"></div>
            <div class="panel-head mt-12">
              <h2 id="trustPanelTitle">Trust</h2>
            </div>
            <div id="trustStrip" class="trust-strip"></div>
          </article>

          <article class="glass panel">
            <div class="panel-head">
              <h2 id="liveTitle">Live Game</h2>
              <span id="liveGameMeta" class="meta">-</span>
            </div>
            <div id="gameTimeline" class="game-timeline"></div>
            <div id="liveState" class="live-state"></div>
            <div id="liveInsights" class="live-insights"></div>
            <div class="action-form">
              <label id="buyQtyLabel" for="buyQtyInput">Qty</label>
              <input id="buyQtyInput" type="number" min="1" max="50" value="1" />
              <button id="buyCardsBtn" class="small-btn primary" type="button">Buy</button>
              <div id="buyStatusHint" class="step-hint"></div>
            </div>
            <div id="liveEvents" class="events-list"></div>
          </article>
        </section>

        <section id="view-cards" class="view">
          <article id="cardsPanel" class="glass panel cards-panel">
            <div class="panel-head">
              <h2 id="cardsTitle">My Cards</h2>
              <button id="refreshCardsBtn" class="small-btn" type="button">Refresh</button>
            </div>
            <p id="cardsHint" class="hint">Live cards</p>

            <div id="cardsPullHint" class="pull-hint" data-state="idle">Pull down to refresh</div>

            <div id="cardsLiveBadge" class="cards-live-badge">
              <div class="cards-live-head">
                <span id="cardsLiveStatus" class="status-pill">-</span>
                <span id="cardsLiveLast" class="last-number">-</span>
              </div>
              <div id="cardsCalledStream" class="cards-called-stream"></div>
            </div>

            <div class="cards-box">
              <div class="cards-box-head">
                <h3 id="cardsActiveTitle">Active Purchased Cards</h3>
                <span id="cardsActiveMeta" class="meta">-</span>
              </div>
              <div id="cardsActiveList" class="cards-active-list"></div>
            </div>

            <div class="cards-box mt-12">
              <div class="cards-box-head">
                <h3 id="cardsHistoryTitle">Purchase History</h3>
                <span id="cardsHistoryMeta" class="meta">Scrollable</span>
              </div>
              <div id="cardsHistoryList" class="cards-history-scroll"></div>
            </div>

            <div class="cards-box mt-12">
              <div class="cards-box-head">
                <h3 id="cardsWinsTitle">Win Timeline</h3>
                <select id="winsGameFilter" class="small-select"></select>
              </div>
              <div id="cardsWinsTimeline" class="cards-history-scroll"></div>
            </div>
          </article>
        </section>

        <section id="view-wallet" class="view">
          <article class="glass panel">
            <div class="panel-head">
              <h2 id="walletTitle">Wallet</h2>
              <button id="refreshWalletBtn" class="small-btn" type="button">Refresh</button>
            </div>
            <div class="wallet-balance-wrap">
              <span id="walletBalanceLabel">Balance</span>
              <strong id="walletBalance">-</strong>
            </div>

            <div class="wallet-flow-grid">
              <div class="deposit-flow flow-card">
                <div class="deposit-flow-head">
                  <h3 id="depositFlowTitle">Deposit</h3>
                  <p id="depositFlowDesc">Steps</p>
                </div>

                <div class="deposit-step">
                  <div class="deposit-step-no">1</div>
                  <div class="deposit-step-body">
                    <label id="depositAmountLabel" for="depositAmountInput">Amount</label>
                    <input id="depositAmountInput" type="number" min="1" />
                  </div>
                </div>

                <div class="deposit-step">
                  <div class="deposit-step-no">2</div>
                  <div class="deposit-step-body">
                    <label id="depositDestinationLabel" for="depositDestinationSelect">Destination</label>
                    <select id="depositDestinationSelect"></select>
                    <div id="depositDestinationHint" class="step-hint"></div>
                  </div>
                </div>

                <div class="deposit-step">
                  <div class="deposit-step-no">3</div>
                  <div class="deposit-step-body">
                    <label id="depositReceiptLabel" for="depositReceiptFileInput">Receipt</label>
                    <input id="depositReceiptFileInput" type="file" accept="image/*,.pdf" />
                  </div>
                </div>

                <div class="deposit-step final">
                  <div class="deposit-step-no">4</div>
                  <div class="deposit-step-body">
                    <label id="depositSubmitLabel">Submit</label>
                    <button id="submitDepositBtn" class="small-btn primary" type="button">Submit Deposit</button>
                    <div id="depositSubmitHint" class="step-hint"></div>
                  </div>
                </div>
              </div>

              <div class="withdraw-flow flow-card">
                <div class="withdraw-flow-head">
                  <h3 id="withdrawFlowTitle">Withdraw</h3>
                  <p id="withdrawFlowDesc">Steps</p>
                </div>

                <div class="deposit-step">
                  <div class="deposit-step-no">1</div>
                  <div class="deposit-step-body">
                    <label id="withdrawLabel" for="withdrawAmountInput">Amount</label>
                    <input id="withdrawAmountInput" type="number" min="1" />
                  </div>
                </div>

                <div class="deposit-step">
                  <div class="deposit-step-no">2</div>
                  <div class="deposit-step-body">
                    <label id="withdrawFullNameLabel" for="withdrawFullNameInput">Full Name</label>
                    <input id="withdrawFullNameInput" type="text" />
                    <label id="withdrawCardLabel" for="withdrawCardInput">Card Number</label>
                    <input id="withdrawCardInput" type="text" />
                  </div>
                </div>

                <div class="deposit-step">
                  <div class="deposit-step-no">3</div>
                  <div class="deposit-step-body">
                    <label id="withdrawIbanLabel" for="withdrawIbanInput">IBAN</label>
                    <input id="withdrawIbanInput" type="text" />
                    <label id="withdrawAccountLabel" for="withdrawAccountInput">Account Number</label>
                    <input id="withdrawAccountInput" type="text" />
                    <div id="withdrawPreviewHint" class="step-hint"></div>
                  </div>
                </div>

                <div class="deposit-step final">
                  <div class="deposit-step-no">4</div>
                  <div class="deposit-step-body">
                    <label id="withdrawSubmitLabel">Submit</label>
                    <button id="submitWithdrawBtn" class="small-btn primary" type="button">Submit Withdraw</button>
                    <div id="withdrawSubmitHint" class="step-hint"></div>
                  </div>
                </div>
              </div>
            </div>

            <div id="walletTxs" class="stack-list"></div>

            <div class="panel-head mt-12">
              <h2 id="depositRequestsTitle">Deposits</h2>
            </div>
            <div id="depositRequestsList" class="stack-list"></div>

            <div class="panel-head mt-12">
              <h2 id="withdrawRequestsTitle">Withdraws</h2>
            </div>
            <div id="withdrawRequestsList" class="stack-list"></div>
          </article>
        </section>
      </main>

      <nav class="bottom-nav glass">
        <button class="nav-btn active" data-view="games" type="button">
          <span id="navGamesText">Games</span>
        </button>
        <button class="nav-btn" data-view="cards" type="button">
          <span id="navCardsText">My Cards</span>
        </button>
        <button class="nav-btn" data-view="wallet" type="button">
          <span id="navWalletText">Wallet</span>
        </button>
      </nav>
    </div>

    <div id="winnerModal" class="winner-modal" aria-hidden="true">
      <div class="winner-modal-card glass">
        <div class="winner-modal-head">
          <h2 id="winnerModalTitle">Winner</h2>
          <button id="winnerCloseBtn" class="icon-btn" type="button" aria-label="close">×</button>
        </div>
        <p id="winnerModalKind" class="winner-modal-kind"></p>
        <p id="winnerModalAmount" class="winner-modal-amount"></p>
        <p id="winnerModalGame" class="winner-modal-game"></p>
        <div class="winner-modal-actions">
          <button id="winnerWalletBtn" class="small-btn primary" type="button">Open Wallet</button>
          <button id="winnerDismissBtn" class="small-btn" type="button">Close</button>
        </div>
      </div>
    </div>

    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="./app.js?v=20260224g" type="module"></script>
  </body>
</html>
